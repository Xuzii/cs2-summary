# Required. Create a webhook in your Discord server:
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# Optional. Override the CS2 replays folder. If unset, auto-detected from
# Steam registry, falling back to common install paths.
# Example (Windows):
# DEMOS_FOLDER=C:\Program Files (x86)\Steam\steamapps\common\Counter-Strike 2\game\csgo\replays
DEMOS_FOLDER=

# Optional. Where to write temporary parser output. Defaults to ./data
# Cleared after each successful run.
DATA_DIR=

# --- Auto-pull mode (npm run fetch / npm run poll) ---

# Optional. Your 17-digit SteamID64 (e.g. 76561198XXXXXXXXX).
# How to find it: open Steam -> your profile -> View Profile. If the URL
# ends with /profiles/<17 digits>, that number is your SteamID64. If it
# ends with /id/<name>/, paste the URL into https://steamid.io to look it up.
# When set, we verify Steam is signed in as this account before downloading.
STEAM_ID64=

# Optional. Poll interval for `npm run poll` in milliseconds.
# Default 900000 (15 minutes). Minimum enforced: 30000 (30 seconds).
POLL_INTERVAL_MS=

# Optional. Where to save auto-downloaded demos. Defaults to the CS2
# replays folder so downloaded demos live alongside any local GOTV files.
DEMO_DOWNLOAD_FOLDER=

# Optional. Comma-separated SteamID64s (17 digits each) to render per-player
# performance cards for, in order. STEAM_ID64 (above) is auto-prepended if set,
# so don't list it here — it renders first.
# Example:
# TRACKED_PLAYERS=76561198049120846,76561198053011290,76561198075568330,76561198227686568
TRACKED_PLAYERS=
